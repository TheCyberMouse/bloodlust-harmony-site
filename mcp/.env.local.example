# =============================================================================
# Bloodlust & Harmony wiki MCP - local env vars
# =============================================================================
# Copy to .env.local and fill in. NEVER commit .env.local (gitignored).

# Supabase project (SAME project the website + WikiSync use)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket (created in wiki setup)
SUPABASE_STORAGE_BUCKET=icons

# Bearer token the MCP requires on every request. Generate a fresh random
# string and use the SAME value when registering the connector in Claude.
MCP_SHARED_SECRET=

# Deploy hook URL for the WEBSITE Vercel project (not the MCP project).
# trigger_deploy POSTs here to rebuild the live site after a content edit.
DEPLOY_HOOK_URL=
